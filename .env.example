# ── Gemini LLM Configuration ───────────────────────────────────────────
# Add your Google Gemini API key from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024

# ── Database Configurations ──────────────────────────────────────────────
# SQLite async connection string
DATABASE_URL=sqlite+aiosqlite:///data/emails.db

# ── FAISS Vector Database Configuration ──────────────────────────────────
# Absolute or relative paths to vector index files
FAISS_INDEX_PATH=data/faiss.index
FAISS_METADATA_PATH=data/faiss_meta.json

# ── Backend Configuration ──────────────────────────────────────────────
# Allowed CORS origins (JSON array format)
ALLOWED_ORIGINS=["http://localhost:3000"]
DEBUG=false
LOG_LEVEL=INFO

# ── Frontend Configuration ─────────────────────────────────────────────
# Address of the backend server (used by Next.js app)
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
MODEL_NAME=gemini-2.0-flash
